COMPOSE_ENV_FILE=.env

ASPNETCORE_ENVIRONMENT=Development

POSTGRES_DB=sponsorship_approval
POSTGRES_USER=sponsorship_app
POSTGRES_PASSWORD=change-me-local-postgres-password

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-local-minio-password

ConnectionStrings__Default=Host=db;Port=5432;Database=sponsorship_approval;Username=sponsorship_app;Password=change-me-local-postgres-password
Minio__Endpoint=http://minio:9000
Minio__AccessKey=minioadmin
Minio__SecretKey=change-me-local-minio-password

Jwt__Issuer=sponsorship-approval-local
Jwt__Audience=sponsorship-approval-api
Jwt__SigningKey=change-me-local-jwt-signing-key-at-least-32-characters
Jwt__AccessTokenLifetimeMinutes=15
Jwt__RefreshTokenLifetimeDays=7
